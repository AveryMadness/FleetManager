@model FleetManager.Models.Reservation
@{ ViewData["Title"] = $"Reservation #{Model.Id}"; }

@section TopbarActions {
  @if (Model.Status == FleetManager.Models.ReservationStatus.Active)
  {
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm">Edit</a>
    <form asp-action="Cancel" asp-route-id="@Model.Id" method="post" class="d-inline">
      @Html.AntiForgeryToken()
      <button class="btn btn-outline-danger btn-sm" data-confirm="Cancel this reservation?">Cancel</button>
    </form>
  }
  <a asp-action="Index" class="btn btn-outline-secondary btn-sm">← Back</a>
}

<div class="row g-3">
  <!-- Left column -->
  <div class="col-lg-8">
    <!-- Reservation info -->
    <div class="card mb-3">
      <div class="card-header d-flex justify-content-between align-items-center">
        Reservation details
        <span class="badge-status badge-@Model.Status.ToString().ToLower()">@Model.Status</span>
      </div>
      <div class="card-body">
        <div class="row g-2" style="font-size:13.5px">
          <div class="col-sm-6"><span class="text-muted">Customer:</span>
            <a asp-controller="Customer" asp-action="Details" asp-route-id="@Model.CustomerId">
              @Model.Customer?.FullName
            </a>
          </div>
          <div class="col-sm-6"><span class="text-muted">Vehicle:</span>
            <a asp-controller="Vehicle" asp-action="Details" asp-route-id="@Model.VehicleId">
              @Model.Vehicle?.Year @Model.Vehicle?.Make @Model.Vehicle?.Model (@Model.Vehicle?.LicensePlate)
            </a>
          </div>
          <div class="col-sm-3"><span class="text-muted">Pick-up:</span> @Model.StartDate.ToString("MMM d, yyyy")</div>
          <div class="col-sm-3"><span class="text-muted">Return:</span>  @Model.EndDate.ToString("MMM d, yyyy")</div>
          <div class="col-sm-3"><span class="text-muted">Duration:</span> @Model.TotalDays day(s)</div>
          <div class="col-sm-3"><span class="text-muted">Created:</span> @Model.CreatedAt.ToString("MMM d, yyyy")</div>
          @if (!string.IsNullOrEmpty(Model.PickupLocation))
          {
            <div class="col-sm-6"><span class="text-muted">Pick-up location:</span> @Model.PickupLocation</div>
          }
          @if (!string.IsNullOrEmpty(Model.ReturnLocation))
          {
            <div class="col-sm-6"><span class="text-muted">Return location:</span> @Model.ReturnLocation</div>
          }
          @if (!string.IsNullOrEmpty(Model.Notes))
          {
            <div class="col-12"><span class="text-muted">Notes:</span> @Model.Notes</div>
          }
          <div class="col-12"><span class="text-muted">Handled by:</span> @(Model.HandledBy?.FullName ?? "—")</div>
        </div>
      </div>
    </div>

    <!-- Complete reservation form -->
    @if (Model.Status == FleetManager.Models.ReservationStatus.Active)
    {
      <div class="card mb-3">
        <div class="card-header">Mark as completed</div>
        <div class="card-body">
          <form asp-action="Complete" asp-route-id="@Model.Id" method="post" class="row g-2 align-items-end">
            @Html.AntiForgeryToken()
            <div class="col-sm-6">
              <label class="form-label">Mileage at return (km)</label>
              <input name="mileageReturned" type="number" class="form-control"
                     value="@Model.Vehicle?.Mileage" min="@Model.Vehicle?.Mileage"/>
            </div>
            <div class="col-sm-6">
              <button type="submit" class="btn btn-success w-100"
                      data-confirm="Mark this reservation as completed?">
                <i class="bi bi-check-circle me-1"></i> Complete
              </button>
            </div>
          </form>
        </div>
      </div>
    }
  </div>

  <!-- Right column — Invoice -->
  <div class="col-lg-4">
    @if (Model.Invoice is not null)
    {
      <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
          Invoice #@Model.Invoice.Id
          <span class="badge-status badge-@Model.Invoice.PaymentStatus.ToString().ToLower()">
            @Model.Invoice.PaymentStatus
          </span>
        </div>
        <div class="card-body">
          <div class="invoice-line">
            <span>Base (@Model.Vehicle?.DailyRate.ToString("C0") × @Model.TotalDays days)</span>
            <span>@Model.Invoice.BaseAmount.ToString("C2")</span>
          </div>
          @foreach (var charge in Model.Invoice.AdditionalCharges)
          {
            <div class="invoice-line">
              <span>@charge.Description</span>
              <span>@charge.Amount.ToString("C2")</span>
            </div>
          }
          @if (Model.Invoice.Discount > 0)
          {
            <div class="invoice-line text-success">
              <span>Discount</span><span>−@Model.Invoice.Discount.ToString("C2")</span>
            </div>
          }
          <div class="invoice-line">
            <span>Tax (13%)</span><span>@Model.Invoice.TaxAmount.ToString("C2")</span>
          </div>
          <div class="invoice-line">
            <span>Total</span><span>@Model.Invoice.TotalAmount.ToString("C2")</span>
          </div>

          <div class="mt-3 d-flex flex-column gap-2">
            @if (Model.Invoice.PaymentStatus != FleetManager.Models.PaymentStatus.Paid)
            {
              <form asp-controller="Billing" asp-action="MarkPaid" asp-route-id="@Model.Invoice.Id" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-success w-100 btn-sm">
                  <i class="bi bi-check me-1"></i> Mark as paid
                </button>
              </form>
            }
            <a asp-controller="Billing" asp-action="Details" asp-route-id="@Model.Invoice.Id"
               class="btn btn-outline-secondary btn-sm">View full invoice</a>
          </div>
        </div>
      </div>
    }
  </div>
</div>
