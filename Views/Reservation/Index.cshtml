@model IEnumerable<FleetManager.Models.Reservation>
@{ ViewData["Title"] = "Reservations"; }

@section TopbarActions {
  <a asp-action="Create" class="btn btn-primary btn-sm">
    <i class="bi bi-plus-lg me-1"></i> New Reservation
  </a>
}

<!-- Filters -->
<form method="get" class="row g-2 mb-4">
  <div class="col-md-4">
    <input name="search" value="@ViewBag.Search" class="form-control" placeholder="Search customer or plate…"/>
  </div>
  <div class="col-md-2">
    <input name="startDate" type="date" value="@ViewBag.StartDate" class="form-control"/>
  </div>
  <div class="col-md-2">
    <input name="endDate" type="date" value="@ViewBag.EndDate" class="form-control"/>
  </div>
  <div class="col-md-2">
    <select name="status" class="form-select">
      <option value="">All statuses</option>
      @foreach (var s in Enum.GetValues<FleetManager.Models.ReservationStatus>())
      {
        <option value="@s" selected="@(ViewBag.StatusFilter?.ToString() == s.ToString())">@s</option>
      }
    </select>
  </div>
  <div class="col-md-2 d-flex gap-2">
    <button type="submit" class="btn btn-primary flex-grow-1">Filter</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
  </div>
</form>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover mb-0">
      <thead>
        <tr>
          <th>#</th>
          <th>Customer</th>
          <th>Vehicle</th>
          <th>Pick-up</th>
          <th>Return</th>
          <th>Days</th>
          <th>Status</th>
          <th>Total</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        @if (!Model.Any())
        {
          <tr><td colspan="9" class="text-center text-muted py-4">No reservations found.</td></tr>
        }
        @foreach (var r in Model)
        {
          <tr>
            <td><a asp-action="Details" asp-route-id="@r.Id">#@r.Id</a></td>
            <td>@r.Customer?.FullName</td>
            <td>@r.Vehicle?.Make @r.Vehicle?.Model</td>
            <td>@r.StartDate.ToString("MMM d, yyyy")</td>
            <td>@r.EndDate.ToString("MMM d, yyyy")</td>
            <td>@r.TotalDays</td>
            <td>
              <span class="badge-status badge-@r.Status.ToString().ToLower()">@r.Status</span>
            </td>
            <td>@r.Invoice?.TotalAmount.ToString("C2")</td>
            <td>
              <div class="d-flex gap-1">
                <a asp-action="Details" asp-route-id="@r.Id" class="btn btn-sm btn-outline-secondary">View</a>
                @if (r.Status == FleetManager.Models.ReservationStatus.Active ||
                     r.Status == FleetManager.Models.ReservationStatus.Pending)
                {
                  <a asp-action="Edit" asp-route-id="@r.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                  <form asp-action="Cancel" asp-route-id="@r.Id" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-outline-danger"
                            data-confirm="Cancel reservation #@r.Id?">Cancel</button>
                  </form>
                }
              </div>
            </td>
          </tr>
        }
      </tbody>
    </table>
  </div>
</div>
