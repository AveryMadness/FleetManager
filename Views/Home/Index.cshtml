@model FleetManager.Models.ViewModels.DashboardViewModel
@{ ViewData["Title"] = "Dashboard"; }

@section TopbarActions {
  <a asp-controller="Reservation" asp-action="Create" class="btn btn-primary btn-sm">
    <i class="bi bi-plus-lg me-1"></i> New Reservation
  </a>
}

<!-- Stat cards -->
<div class="row g-3 mb-4">
  <div class="col-sm-6 col-xl-3">
    <div class="stat-card">
      <div class="stat-label">Total Vehicles</div>
      <div class="stat-value">@Model.TotalVehicles</div>
      <div class="stat-delta text-muted">@Model.AvailableVehicles available</div>
      <i class="bi bi-car-front stat-icon"></i>
    </div>
  </div>
  <div class="col-sm-6 col-xl-3">
    <div class="stat-card">
      <div class="stat-label">Active Reservations</div>
      <div class="stat-value">@Model.ActiveReservations</div>
      <div class="stat-delta text-muted">Currently ongoing</div>
      <i class="bi bi-calendar-check stat-icon"></i>
    </div>
  </div>
  <div class="col-sm-6 col-xl-3">
    <div class="stat-card">
      <div class="stat-label">Monthly Revenue</div>
      <div class="stat-value">@Model.MonthlyRevenue.ToString("C0")</div>
      <div class="stat-delta text-muted">Paid invoices this month</div>
      <i class="bi bi-cash-stack stat-icon"></i>
    </div>
  </div>
  <div class="col-sm-6 col-xl-3">
    <div class="stat-card">
      <div class="stat-label">Outstanding</div>
      <div class="stat-value @(Model.OutstandingDebt > 0 ? "text-danger" : "")">
        @Model.OutstandingDebt.ToString("C0")
      </div>
      <div class="stat-delta text-muted">Unpaid invoices</div>
      <i class="bi bi-exclamation-circle stat-icon"></i>
    </div>
  </div>
</div>

<div class="row g-3 mb-4">
  <!-- Weekly chart -->
  <div class="col-lg-8">
    <div class="card h-100">
      <div class="card-header d-flex justify-content-between align-items-center">
        Reservations — last 7 days
      </div>
      <div class="card-body">
        <div class="chart-container">
          <canvas id="weeklyChart"
                  data-labels='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.WeeklyStats.Select(s => s.Day)))'
                  data-values='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.WeeklyStats.Select(s => s.Count)))'></canvas>
        </div>
      </div>
    </div>
  </div>

  <!-- Fleet status donut -->
  <div class="col-lg-4">
    <div class="card h-100">
      <div class="card-header">Fleet status</div>
      <div class="card-body d-flex flex-column gap-2 justify-content-center">
        @{
          var statusGroups = new[]
          {
            (Label:"Available",   Cls:"badge-available",   Icon:"bi-check-circle",     Count:Model.AvailableVehicles),
            (Label:"Rented",      Cls:"badge-rented",       Icon:"bi-key",              Count:Model.TotalVehicles - Model.AvailableVehicles),
          };
        }
        @foreach (var s in statusGroups)
        {
          <div class="d-flex align-items-center gap-2">
            <i class="bi @s.Icon me-1"></i>
            <span class="flex-grow-1">@s.Label</span>
            <span class="badge-status @s.Cls">@s.Count</span>
          </div>
        }
      </div>
    </div>
  </div>
</div>

<!-- Recent reservations -->
<div class="card">
  <div class="card-header d-flex justify-content-between align-items-center">
    Recent reservations
    <a asp-controller="Reservation" asp-action="Index" class="btn btn-sm btn-outline-primary">View all</a>
  </div>
  <div class="table-responsive">
    <table class="table table-hover mb-0">
      <thead>
        <tr>
          <th>#</th><th>Customer</th><th>Vehicle</th>
          <th>Pick-up</th><th>Return</th><th>Status</th><th>Actions</th>
        </tr>
      </thead>
      <tbody>
        @foreach (var r in Model.RecentReservations)
        {
          <tr>
            <td><a asp-controller="Reservation" asp-action="Details" asp-route-id="@r.Id">#@r.Id</a></td>
            <td>@r.Customer?.FullName</td>
            <td>@r.Vehicle?.Make @r.Vehicle?.Model</td>
            <td>@r.StartDate.ToString("MMM d")</td>
            <td>@r.EndDate.ToString("MMM d")</td>
            <td>
              <span class="badge-status badge-@r.Status.ToString().ToLower()">@r.Status</span>
            </td>
            <td>
              <a asp-controller="Reservation" asp-action="Details" asp-route-id="@r.Id"
                 class="btn btn-xs btn-outline-secondary btn-sm">View</a>
            </td>
          </tr>
        }
      </tbody>
    </table>
  </div>
</div>
