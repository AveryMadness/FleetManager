<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>@ViewData["Title"] – FleetManager</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"/>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
  <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
</head>
<body>

@if (User.Identity?.IsAuthenticated == true)
{
<div class="d-flex" id="app-shell">

  <!-- ── Sidebar ─────────────────────────────────────────────── -->
  <nav id="sidebar" class="d-flex flex-column flex-shrink-0 p-0">
    <a class="sidebar-brand d-flex align-items-center gap-2 px-3 py-3 text-decoration-none" asp-controller="Home" asp-action="Index">
      <i class="bi bi-truck fs-5"></i>
      <span class="brand-text fw-semibold">FleetManager</span>
    </a>

    <ul class="nav nav-pills flex-column mb-auto px-2">
      <li class="nav-item">
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
           asp-controller="Home" asp-action="Index">
          <i class="bi bi-speedometer2 me-2"></i> Dashboard
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Vehicle" ? "active" : "")"
           asp-controller="Vehicle" asp-action="Index">
          <i class="bi bi-car-front me-2"></i> Vehicles
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reservation" ? "active" : "")"
           asp-controller="Reservation" asp-action="Index">
          <i class="bi bi-calendar3 me-2"></i> Reservations
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Customer" ? "active" : "")"
           asp-controller="Customer" asp-action="Index">
          <i class="bi bi-people me-2"></i> Customers
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Billing" ? "active" : "")"
           asp-controller="Billing" asp-action="Index">
          <i class="bi bi-receipt me-2"></i> Billing
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Report" ? "active" : "")"
           asp-controller="Report" asp-action="Index">
          <i class="bi bi-bar-chart-line me-2"></i> Reports
        </a>
      </li>

      @if (User.IsInRole("Admin"))
      {
      <li class="nav-item mt-3">
        <small class="nav-section-label px-3">Admin</small>
      </li>
      <li class="nav-item">
        <a class="nav-link" asp-controller="Account" asp-action="Register">
          <i class="bi bi-person-plus me-2"></i> Add User
        </a>
      </li>
      }
    </ul>

    <div class="sidebar-footer px-3 py-2 border-top">
      <div class="d-flex align-items-center gap-2">
        <div class="avatar-sm">@User.Identity!.Name![..1].ToUpper()</div>
        <div class="small lh-sm overflow-hidden">
          <div class="fw-medium text-truncate">@User.Identity.Name</div>
          <div class="text-muted" style="font-size:11px">@(User.IsInRole("Admin") ? "Administrator" : "Staff")</div>
        </div>
        <form asp-controller="Account" asp-action="Logout" method="post" class="ms-auto">
          @Html.AntiForgeryToken()
          <button type="submit" class="btn btn-link p-0 text-muted" title="Sign out">
            <i class="bi bi-box-arrow-right"></i>
          </button>
        </form>
      </div>
    </div>
  </nav>

  <!-- ── Main content ────────────────────────────────────────── -->
  <div class="flex-grow-1 d-flex flex-column" id="main-content">
    <header class="topbar d-flex align-items-center px-4">
      <button class="btn btn-link p-0 me-3 d-lg-none" id="sidebarToggle">
        <i class="bi bi-list fs-5"></i>
      </button>
      <h1 class="page-title mb-0">@ViewData["Title"]</h1>
      <div class="ms-auto d-flex gap-2">
        @RenderSection("TopbarActions", required: false)
      </div>
    </header>

    <main class="flex-grow-1 p-4 overflow-auto">
      @if (TempData["Success"] is string success)
      {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
          <i class="bi bi-check-circle me-2"></i>@success
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      }
      @if (TempData["Error"] is string error)
      {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
          <i class="bi bi-exclamation-circle me-2"></i>@error
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      }

      @RenderBody()
    </main>
  </div>
</div>
}
else
{
  @RenderBody()
}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
