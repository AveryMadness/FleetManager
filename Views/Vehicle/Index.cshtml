@model IEnumerable<FleetManager.Models.Vehicle>
@{ ViewData["Title"] = "Vehicles"; }

@section TopbarActions {
  @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
  {
    <a asp-action="Create" class="btn btn-primary btn-sm">
      <i class="bi bi-plus-lg me-1"></i> Add Vehicle
    </a>
  }
}

<!-- Filters -->
<form method="get" class="row g-2 mb-4">
  <div class="col-md-5">
    <input name="search" value="@ViewBag.Search" class="form-control"
           placeholder="Search make, model, plate…"/>
  </div>
  <div class="col-md-3">
    <select name="categoryId" class="form-select" asp-items="@ViewBag.Categories">
      <option value="">All categories</option>
    </select>
  </div>
  <div class="col-md-2">
    <select name="status" class="form-select">
      <option value="">All statuses</option>
      @foreach (var s in Enum.GetValues<FleetManager.Models.VehicleStatus>())
      {
        <option value="@s" selected="@(ViewBag.StatusFilter?.ToString() == s.ToString())">@s</option>
      }
    </select>
  </div>
  <div class="col-md-2 d-flex gap-2">
    <button type="submit" class="btn btn-primary flex-grow-1">Filter</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
  </div>
</form>

@if (!Model.Any())
{
  <div class="text-center text-muted py-5">
    <i class="bi bi-car-front fs-1 d-block mb-2 opacity-25"></i>
    No vehicles found.
  </div>
}
else
{
  <div class="row g-3">
    @foreach (var v in Model)
    {
      <div class="col-sm-6 col-lg-4 col-xl-3">
        <div class="vehicle-card h-100">
          <div class="vehicle-card-img">
            @if (!string.IsNullOrEmpty(v.ImageUrl))
            { <img src="@v.ImageUrl" alt="@v.Make @v.Model"/> }
            else
            { <i class="bi bi-car-front"></i> }
          </div>
          <div class="vehicle-card-body">
            <div class="d-flex justify-content-between align-items-start mb-1">
              <div>
                <div class="vehicle-card-title">@v.Year @v.Make @v.Model</div>
                <div class="vehicle-card-sub">@v.LicensePlate · @v.Category?.Name</div>
              </div>
              <span class="badge-status badge-@v.Status.ToString().ToLower()">@v.Status</span>
            </div>
            <div class="d-flex justify-content-between align-items-center mt-2">
              <strong class="text-primary-custom">@v.DailyRate.ToString("C0") / day</strong>
              <div class="d-flex gap-1">
                <a asp-action="Details" asp-route-id="@v.Id" class="btn btn-sm btn-outline-secondary">View</a>
                @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
                {
                  <a asp-action="Edit" asp-route-id="@v.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                }
              </div>
            </div>
          </div>
        </div>
      </div>
    }
  </div>
}
