@model FleetManager.Models.Customer
@{ ViewData["Title"] = Model.FullName; }

@section TopbarActions {
  <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm">Edit</a>
  <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back</a>
}

<div class="row g-3">
  <div class="col-lg-4">
    <div class="card text-center p-3 mb-3">
      <div class="mx-auto mb-3 d-flex align-items-center justify-content-center rounded-circle fw-bold"
           style="width:72px;height:72px;background:#EEEDFE;color:#534AB7;font-size:24px">
        @Model.FirstName[..1]@Model.LastName[..1]
      </div>
      <h5 class="mb-1">@Model.FullName</h5>
      <span class="badge-status badge-@Model.Status.ToString().ToLower()">@Model.Status</span>
      <hr/>
      <div class="text-start" style="font-size:13px">
        <div class="mb-2"><i class="bi bi-envelope me-2 text-muted"></i>@Model.Email</div>
        @if (!string.IsNullOrEmpty(Model.Phone))
        { <div class="mb-2"><i class="bi bi-telephone me-2 text-muted"></i>@Model.Phone</div> }
        <div class="mb-2"><i class="bi bi-card-text me-2 text-muted"></i><code>@Model.LicenseNumber</code></div>
        @if (Model.DateOfBirth.HasValue)
        { <div class="mb-2"><i class="bi bi-calendar me-2 text-muted"></i>@Model.DateOfBirth.Value.ToString("MMM d, yyyy")</div> }
        @if (!string.IsNullOrEmpty(Model.Address))
        { <div class="mb-2"><i class="bi bi-geo-alt me-2 text-muted"></i>@Model.Address</div> }
        <div class="text-muted small mt-2">Member since @Model.CreatedAt.ToString("MMM yyyy")</div>
      </div>
    </div>
    <div class="card p-3">
      <div class="row g-2 text-center">
        <div class="col-6">
          <div style="font-size:22px;font-weight:700;color:#534AB7">@Model.Reservations.Count</div>
          <div class="text-muted small">Total bookings</div>
        </div>
        <div class="col-6">
          <div style="font-size:22px;font-weight:700;color:#534AB7">
            @Model.Reservations.Where(r => r.Invoice != null).Sum(r => r.Invoice!.TotalAmount).ToString("C0")
          </div>
          <div class="text-muted small">Total spent</div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-lg-8">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        Reservation history
        <a asp-controller="Reservation" asp-action="Create" class="btn btn-sm btn-primary">
          <i class="bi bi-plus me-1"></i> New
        </a>
      </div>
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead>
            <tr><th>#</th><th>Vehicle</th><th>Dates</th><th>Status</th><th>Total</th></tr>
          </thead>
          <tbody>
            @if (!Model.Reservations.Any())
            {
              <tr><td colspan="5" class="text-center text-muted py-3">No reservations yet.</td></tr>
            }
            @foreach (var r in Model.Reservations.OrderByDescending(r => r.CreatedAt))
            {
              <tr>
                <td><a asp-controller="Reservation" asp-action="Details" asp-route-id="@r.Id">#@r.Id</a></td>
                <td>@r.Vehicle?.Make @r.Vehicle?.Model</td>
                <td style="font-size:12.5px">@r.StartDate.ToString("MMM d") - @r.EndDate.ToString("MMM d, yyyy")</td>
                <td><span class="badge-status badge-@r.Status.ToString().ToLower()">@r.Status</span></td>
                <td>@r.Invoice?.TotalAmount.ToString("C2")</td>
              </tr>
            }
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
